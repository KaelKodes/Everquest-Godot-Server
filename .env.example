# Copy to .env and fill in values. Never commit .env.
# See server/README.md for full setup (MariaDB / Redis / cluster).

# --- Required: PEQ-style MariaDB (EQEmu / Akkadius stack) ---
EQEMU_HOST=127.0.0.1
EQEMU_PORT=3307
EQEMU_USER=eqemu
EQEMU_PASSWORD=change_me
EQEMU_DATABASE=peq

# --- Redis (world server broker; cluster layout) ---
# Default matches local Redis. Docker: often redis://127.0.0.1:6379 or host.docker.internal
REDIS_URL=redis://127.0.0.1:6379

# --- Server identity (what the client's Server Select screen shows) ---
# Naming convention:
#   - "Mithaniel Marr" → active dev box (this machine, new features first)
#   - "Erollisi Marr"  → public/stable tester host (home machine)
# Reported to clients via SERVER_INFO; if unset, defaults to 'EQMUD'.
# SERVER_NAME=Mithaniel Marr

# --- Public host advertised to remote clients ---
# Set to the IP/hostname your clients will connect to. Leave as 'localhost'
# for a single-machine dev setup. On the public/LAN tester host, set this
# to your WAN IP (e.g. 24.33.88.252) so HANDOFF packets to world/zone
# servers point at an address remote clients can actually reach.
# PUBLIC_HOST=localhost

# --- Cluster ports ---
# Defaults belong to Erollisi Marr (the public/stable host on its own box).
# When two clusters share a WAN IP (e.g. two machines behind the same
# router), pick a non-overlapping range for the secondary deployment so the
# router can port-forward each to the right box.
#
# Mithaniel Marr (this dev box) uses 4xxx so it doesn't collide with the
# Erollisi instance at 3xxx. Uncomment and set per-machine:
# PORT_LOGIN=3005
# PORT_WORLD=3006
# PORT_TUNARE=3010
# PORT_INNORUUK=3011

# --- Optional: override world URL seen by login server ---
# Automatically derived from PUBLIC_HOST when not set.
# WORLD_URL=ws://localhost:3006

# --- Optional: override MariaDB container name for Dump_DB.bat / Import_DB.bat ---
# Defaults to the Akk stack name. Change if you renamed your container.
# MARIADB_CONTAINER=akk-stack-mariadb-1

# --- Optional dev ---
# EQMUD_ALLOW_GM_COMMANDS=1
# SCRIBE_CURVE_MAX_LEVEL=60
